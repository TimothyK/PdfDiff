{
  "manifestVersion": 1,
  "id": "pdf-diff-viewer",
  "name": "PDF Diff Viewer",
  "version": "0.1.28",
  "publisher": "CodeMonkeyProjectiles",
  "description": "View PDF file diffs in pull requests with side-by-side, inline, and pixel diff views",
  "categories": [
    "Azure Repos"
  ],
  "tags": [
    "PDF",
    "Git",
    "Diff",
    "Image",
    "Pixel",
    "Pull Request"
  ],
  "targets": [
    {
      "id": "Microsoft.VisualStudio.Services"
    }
  ],
  "icons": {
    "default": "images/logo.png"
  },
  "content": {
    "details": {
      "path": "README.md"
    },
    "license": {
      "path": "LICENSE"
    }
  },
  "files": [
    {
      "path": "dist",
      "addressable": true
    },
    {
      "path": "images",
      "addressable": true
    }
  ],
  "contributions": [
    {
      "id": "pdf-diff-tab",
      "type": "ms.vss-web.tab",
      "description": "PDF Diff Viewer for Pull Requests",
      "targets": [
        "ms.vss-code-web.pr-tabs"
      ],
      "properties": {
        "name": "PDF Diff",
        "uri": "dist/pr-viewer.html",
        "title": "PDF Diff"
      }
    }
  ],

  "links": {
    "home": {
      "uri": "https://github.com/TimothyK/PdfDiff"
    },
    "getstarted": {
      "uri": "https://github.com/TimothyK/PdfDiff#usage"
    },
    "repository": {
      "uri": "https://github.com/TimothyK/PdfDiff"
    },
    "support": {
      "uri": "https://github.com/TimothyK/PdfDiff/issues"
    },
    "privacypolicy": {
      "uri": "https://github.com/TimothyK/PdfDiff/blob/main/PRIVACY.md"
    }
  },
  "scopes": [
    "vso.code",
    "vso.code_status"
  ]
}
